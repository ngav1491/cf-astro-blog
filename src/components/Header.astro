---
import { buildSiteNavLinks, type SiteAppearance } from "@/lib/site-appearance";
import { siteConfig } from "@/lib/types";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
	siteAppearance: SiteAppearance;
}

const currentPath = Astro.url.pathname;
const { siteAppearance }: Props = Astro.props;
const navLinks = buildSiteNavLinks(siteAppearance);

function isInternalHref(href: string) {
	return href.startsWith("/") && !href.startsWith("//");
}

function isLinkActive(href: string) {
	if (!isInternalHref(href)) {
		return false;
	}

	if (href === "/") {
		return currentPath === "/";
	}

	return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<header class="site-header">
	<nav class="site-nav" transition:persist>
		<div class="site-nav-shell-scroll">
			<div class="site-nav-shell">
				<div class="site-brand">
					<a href="/api/auth/login" class="site-brand-mark-link" aria-label="Mở cổng vào trang web">
						<span class="site-brand-mark" aria-hidden="true">
							<img
								src="https://assets.ericterminal.com/logo-transparent.png"
								alt=""
								loading="eager"
								decoding="async"
							/>
						</span>
					</a>
					<a href="/" class="site-brand-copy-link" aria-label={siteConfig.name}>
						<span class="site-brand-copy">
							<strong>{siteConfig.name}</strong>
							<small>{siteAppearance.headerSubtitle}</small>
						</span>
					</a>
				</div>
				<ul class="nav-links">
					{
						navLinks.map((item) => (
							<li>
								<a
									href={item.href}
									class:list={["nav-link", { active: isLinkActive(item.href) }]}
									data-astro-prefetch={isInternalHref(item.href) ? "load" : undefined}
									target={isInternalHref(item.href) ? undefined : "_blank"}
									rel={isInternalHref(item.href) ? undefined : "noopener noreferrer"}
								>
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
				<div class="nav-actions">
					<ThemeToggle />
				</div>
			</div>
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 30;
		padding-inline: 0;
		pointer-events: none;
		transition:
			top var(--nav-motion-main),
			padding-inline var(--nav-motion-main);
	}

	.site-nav {
		position: relative;
		width: 100%;
		pointer-events: none;
		isolation: isolate;
		contain: paint;
	}

	.site-nav::before {
		content: "";
		position: absolute;
		inset: 0;
		border-top: none;
		border-left: none;
		border-right: none;
		border-bottom: 1px solid var(--color-border);
		border-radius: 0;
		background: var(--nav-shell-open-surface);
		box-shadow: var(--nav-shell-open-shadow);
		backdrop-filter: blur(var(--nav-shell-blur-effective, 14px)) saturate(125%);
		-webkit-backdrop-filter: blur(var(--nav-shell-blur-effective, 14px))
			saturate(125%);
		transform-origin: top center;
		transform: translate3d(0, 0, 0);
		backface-visibility: hidden;
		will-change: inset, border-radius, transform, box-shadow;
		transition:
			inset var(--nav-motion-main),
			border-radius var(--nav-motion-main),
			background-color var(--nav-motion-surface),
			border-color var(--nav-motion-surface),
			box-shadow var(--nav-motion-surface),
			transform var(--nav-motion-transform);
	}

	.site-nav-shell-scroll {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 100vw;
		margin-inline: 0;
		border-radius: 0;
		overflow-x: auto;
		overflow-y: hidden;
		-webkit-overflow-scrolling: touch;
		scrollbar-width: thin;
		scrollbar-color: rgba(10, 132, 255, 0.3) transparent;
		pointer-events: auto;
		will-change: width, margin-inline, border-radius, transform;
		transition:
			width var(--nav-motion-main),
			margin-inline var(--nav-motion-main),
			border-radius var(--nav-motion-main),
			transform var(--nav-motion-transform);
	}

	.site-nav-shell-scroll::-webkit-scrollbar {
		height: 5px;
	}

	.site-nav-shell-scroll::-webkit-scrollbar-track {
		background: transparent;
	}

	.site-nav-shell-scroll::-webkit-scrollbar-thumb {
		border-radius: 999px;
		background: rgba(10, 132, 255, 0.28);
	}

	.site-nav-shell {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 1rem;
		min-width: 100%;
		width: max-content;
		margin-inline: auto;
		padding:
			0.88rem
			calc(1.18rem + env(safe-area-inset-right))
			0.96rem
			calc(1.18rem + env(safe-area-inset-left));
		will-change: max-width;
		transform-origin: top center;
		transform: translate3d(0, 0, 0) scale(1);
		transition:
			gap var(--nav-motion-main),
			padding var(--nav-motion-main),
			transform var(--nav-motion-transform);
	}

	.site-brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		flex: 0 0 auto;
	}

	.site-brand-mark-link,
	.site-brand-copy-link {
		display: inline-flex;
		min-width: 0;
		color: inherit;
	}

	.site-brand-mark-link {
		border-radius: var(--radius-inner);
	}

	.site-brand-copy-link {
		display: grid;
	}

	.site-brand-mark {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.8rem;
		height: 2.8rem;
		border-radius: var(--radius-inner);
		padding: 0.28rem;
		background: rgba(10, 132, 255, 0.1);
		border: 1px solid rgba(10, 132, 255, 0.18);
		box-shadow: 0 12px 28px -24px rgba(10, 132, 255, 0.45);
	}

	.site-brand-mark img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.site-brand-copy {
		display: grid;
		gap: 0.18rem;
		min-width: 0;
	}

	.site-brand-copy strong {
		display: block;
		max-width: 18rem;
		font-size: 1rem;
		font-weight: 700;
		color: var(--color-text);
		letter-spacing: -0.02em;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.site-brand-copy small {
		color: var(--color-text-muted);
		font-size: 0.78rem;
		white-space: nowrap;
		transform-origin: left center;
		transition:
			opacity var(--nav-motion-surface),
			transform var(--nav-motion-main);
	}

	.nav-links,
	.nav-actions {
		display: inline-flex;
		align-items: center;
		gap: var(--space-md);
		list-style: none;
		transition: transform var(--nav-motion-surface);
		transform: translate3d(0, 0, 0);
	}

	.nav-links {
		margin-left: auto;
		flex-wrap: nowrap;
		white-space: nowrap;
		gap: 0.4rem;
	}

	.nav-actions {
		flex: 0 0 auto;
		min-width: max-content;
	}

	.nav-link {
		color: var(--color-text-secondary);
		font-size: 0.92rem;
		padding: 0.72rem 1rem;
		border-radius: var(--radius-pill);
		border: 1px solid transparent;
		background: transparent;
		transition:
			color var(--transition),
			background-color var(--transition),
			border-color var(--transition),
			transform var(--transition);
	}

	.nav-link:hover,
	.nav-link.active {
		color: var(--color-accent);
		background: rgba(10, 132, 255, 0.08);
		border-color: rgba(10, 132, 255, 0.12);
	}

	.nav-link:hover,
	.nav-link.active {
		transform: translateY(-1px);
	}

	:global(html[data-nav-condensed]) .site-header {
		top: 0.75rem;
		padding-inline: 0.8rem;
	}

	:global(html[data-nav-condensed]) .site-nav::before {
		/*
		 * --nav-shell-condensed-computed-inset 由 JS 动态设置：
		 * 内容超出默认 1060px 胶囊时扩展，保证所有导航项可见；
		 * 未设置时降级到原始公式。
		 */
		inset-inline: var(
			--nav-shell-condensed-computed-inset,
			max(
				var(--nav-shell-condensed-inset-desktop),
				calc((100% - var(--nav-shell-max-width)) / 2)
			)
		);
		border: 1px solid var(--color-border);
		border-radius: var(--nav-shell-condensed-radius);
		background: var(--nav-shell-condensed-surface);
		box-shadow: var(--nav-shell-condensed-shadow);
		transform: translate3d(0, 0, 0) scale(var(--nav-shell-condensed-scale));
	}

	:global(html[data-nav-condensed]) .site-nav-shell-scroll {
		width: calc(
			100% -
				2 *
				var(
					--nav-shell-condensed-computed-inset,
					max(
						var(--nav-shell-condensed-inset-desktop),
						calc((100% - var(--nav-shell-max-width)) / 2)
					)
				)
		);
		margin-inline: var(
			--nav-shell-condensed-computed-inset,
			max(
				var(--nav-shell-condensed-inset-desktop),
				calc((100% - var(--nav-shell-max-width)) / 2)
			)
		);
		border-radius: var(--nav-shell-condensed-radius);
		overflow-x: auto;
		overflow-y: hidden;
	}

	:global(html[data-nav-condensed]) .site-nav-shell {
		transform: translate3d(0, 0, 0) scale(var(--nav-shell-condensed-scale));
	}

	:global(html[data-nav-condensed]) .site-brand-copy small {
		opacity: 0.68;
		transform: translateY(-1px);
	}

	:global(html[data-nav-condensed]) .nav-links,
	:global(html[data-nav-condensed]) .nav-actions {
		transform: translate3d(0, -1px, 0);
	}

	@media (max-width: 960px) {
		.site-header {
			top: 0;
			padding-inline: 0;
		}

		.site-nav {
			width: 100%;
		}

		.site-nav-shell {
			gap: 0.72rem;
			padding:
				0.82rem
				calc(0.9rem + env(safe-area-inset-right))
				0.95rem
				calc(0.9rem + env(safe-area-inset-left));
		}

		.site-brand-copy {
			justify-items: start;
		}

		.site-brand-copy small {
			white-space: nowrap;
			text-align: left;
		}

		.nav-links {
			gap: 0.36rem;
		}

		.nav-link {
			padding: 0.62rem 0.78rem;
			font-size: 0.88rem;
			white-space: nowrap;
		}

		.nav-actions :global(.theme-toggle) {
			padding: 0.62rem;
		}

		:global(html[data-nav-condensed]) .site-header {
			top: 0.5rem;
			padding-inline: 0.5rem;
		}

		:global(html[data-nav-condensed]) .site-nav::before {
			inset-inline: var(--nav-shell-condensed-inset-mobile);
			border-radius: 28px;
			transform: translate3d(0, 0, 0) scale(var(--nav-shell-condensed-scale));
		}

		:global(html[data-nav-condensed]) .site-nav-shell {
			transform: translate3d(0, 0, 0) scale(var(--nav-shell-condensed-scale));
		}

		:global(html[data-nav-condensed]) .site-nav-shell-scroll {
			width: calc(100% - (var(--nav-shell-condensed-inset-mobile) * 2));
			margin-inline: var(--nav-shell-condensed-inset-mobile);
			border-radius: 28px;
		}
	}

	@media (max-width: 640px) {
		.site-nav-shell {
			gap: 0.56rem;
			padding: 0.72rem 0.8rem;
		}

		.site-brand {
			gap: 0.52rem;
		}

		.site-brand-mark {
			width: 2.45rem;
			height: 2.45rem;
			padding: 0.22rem;
		}

		.site-brand-copy strong {
			max-width: min(42vw, 10.5rem);
			font-size: 0.92rem;
		}

		.site-brand-copy small {
			display: none;
		}

		.nav-links {
			gap: 0.2rem;
		}

		.nav-link {
			padding: 0.52rem 0.66rem;
			font-size: 0.84rem;
		}

		.nav-actions :global(.theme-toggle) {
			padding: 0.58rem;
		}

		:global(html[data-nav-condensed]) .site-nav::before {
			border-radius: 24px;
		}

		:global(html[data-nav-condensed]) .site-nav-shell-scroll {
			border-radius: 24px;
		}
	}

	/* 主题切换动画期间，View Transition 的截图层会阻断 backdrop-filter 采样，
	 * 导致导航栏的磨玻璃背景变透明并透出下方内容。
	 * 在切换过渡期间改用不透明的背景色兜底，视觉上保持导航栏不透明。 */
	:global([data-theme-switching]) .site-nav::before {
		background: var(--color-bg);
		transition: none;
	}
</style>
