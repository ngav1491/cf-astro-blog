---
interface TaxonomyOption {
	slug: string;
	name: string;
}

interface Props {
	initialQuery?: string;
	categories?: TaxonomyOption[];
	tags?: TaxonomyOption[];
	selectedCategory?: string;
	selectedTags?: string[];
	selectedDateFrom?: string;
	selectedDateTo?: string;
}

const {
	initialQuery = "",
	categories = [],
	tags = [],
	selectedCategory = "",
	selectedTags = [],
	selectedDateFrom = "",
	selectedDateTo = "",
}: Props = Astro.props;

const selectedTagSet = new Set(selectedTags);
const selectedTagItems = tags.filter((tag) => selectedTagSet.has(tag.slug));
const hasDateFilter = Boolean(selectedDateFrom || selectedDateTo);
const selectedDateLabel = hasDateFilter
	? `${selectedDateFrom || "Không giới hạn"} đến ${selectedDateTo || "Không giới hạn"}`
	: "Toàn bộ phạm vi";
---

<div class="search-container">
	<form class="search-form" action="/search" method="get">
		<input
			type="search"
			name="q"
			class="search-input"
			placeholder="Tìm kiếm tiêu đề, tóm tắt hoặc từ khóa bài viết"
			aria-label="Tìm kiếm bài viết"
			autocomplete="off"
			value={initialQuery}
		/>
		{categories.length > 0 ? (
			<select name="category" class="search-select" aria-label="Lọc theo phân loại">
				<option value="">Tất cả phân loại</option>
				{categories.map((category) => (
					<option value={category.slug} selected={selectedCategory === category.slug}>
						{category.name}
					</option>
				))}
			</select>
		) : null}
		<button type="submit" class="button search-button">Bắt đầu tìm kiếm</button>

		{tags.length > 0 ? (
			<div class="search-tags-shell">
				<div class="search-tags-head">
					<span class="search-tags-head-label">Lọc theo thẻ</span>
					{selectedTagItems.length > 0 ? (
						<div class="search-selected-tags" aria-live="polite">
							{selectedTagItems.map((tag) => (
								<span class="search-selected-chip">{tag.name}</span>
							))}
						</div>
					) : (
						<span class="search-selected-empty">Chưa chọn thẻ</span>
					)}
				</div>
				<details class="search-tags-panel">
					<summary>
						{selectedTagItems.length > 0
							? `Điều chỉnh thẻ (đã chọn ${selectedTagItems.length})`
							: "Mở rộng chọn thẻ"}
					</summary>
					<fieldset class="search-tags">
						<legend class="sr-only">Lọc theo thẻ</legend>
								{tags.map((tag) => (
									<label class="search-tag-chip">
										<input
											type="checkbox"
											name="tags"
											value={tag.slug}
											checked={selectedTagSet.has(tag.slug)}
										/>
										<span>{tag.name}</span>
									</label>
								))}
							</div>
						</fieldset>
					</details>
				</div>
			) : null}
			<div class="search-date-shell">
				<div class="search-date-head">
					<span class="search-date-head-label">Khoảng thời gian</span>
					<span class="search-date-hint">{selectedDateLabel}</span>
				</div>
				<details class="search-date-panel">
					<summary>
						{hasDateFilter ? "Điều chỉnh khoảng thời gian (đã đặt)" : "Mở rộng chọn khoảng thời gian"}
					</summary>
					<div class="search-date-body">
						<p class="search-date-tip">Ngày bắt đầu và kết thúc đều có thể để trống; không điền sẽ tìm theo toàn bộ phạm vi.</p>
						<div class="search-date-row">
							<label class="search-date-field">
								<span>Từ</span>
								<input
									type="date"
									name="dateFrom"
									class="search-date-input"
									aria-label="Ngày bắt đầu"
									value={selectedDateFrom}
								/>
							</label>
							<label class="search-date-field">
								<span>Đến</span>
								<input
									type="date"
									name="dateTo"
									class="search-date-input"
									aria-label="Ngày kết thúc"
									value={selectedDateTo}
								/>
							</label>
						</div>
					</div>
				</details>
			</div>
		</form>
		<div id="search-results" class="search-results"></div>
</div>

<style>
	.search-container {
		width: 100%;
		max-width: 46rem;
	}

	.search-form {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		padding: 0.7rem;
		border-radius: var(--radius-card);
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.12);
		backdrop-filter: blur(12px) saturate(120%);
		-webkit-backdrop-filter: blur(12px) saturate(120%);
	}

	.search-input,
	.search-select,
	.search-date-input {
		flex: 1;
		min-width: min(100%, 12rem);
		padding: 0.95rem 1rem;
		border: 1px solid transparent;
		border-radius: var(--radius-pill);
		background-color: transparent;
		color: var(--color-text);
		font-size: var(--font-size-base);
		font-family: var(--font-sans);
		transition:
			border-color var(--transition),
			background-color var(--transition);
	}

	.search-select {
		appearance: none;
	}

	.search-input::placeholder {
		color: var(--color-text-placeholder);
	}

	.search-input:focus,
	.search-select:focus,
	.search-date-input:focus {
		outline: none;
		border-color: rgba(10, 132, 255, 0.22);
		background: var(--color-bg-tertiary);
	}

	.search-date-input {
		min-width: 0;
		width: 100%;
	}

		.search-button {
			padding: 0.95rem 1.2rem;
		}

		.search-tags-shell {
			width: 100%;
			display: grid;
			gap: 0.5rem;
		}

		.search-tags-head {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 0.6rem;
			flex-wrap: wrap;
		}

		.search-tags-head-label {
			font-size: 0.82rem;
			color: var(--color-text-muted);
		}

		.search-selected-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 0.45rem;
			justify-content: flex-end;
		}

		.search-selected-chip {
			padding: 0.3rem 0.62rem;
			border-radius: var(--radius-pill);
			border: 1px solid rgba(10, 132, 255, 0.4);
			background: rgba(10, 132, 255, 0.14);
			font-size: 0.78rem;
			color: var(--color-text);
		}

		.search-selected-empty {
			font-size: 0.78rem;
			color: var(--color-text-muted);
		}

		.search-date-shell {
			width: 100%;
			display: grid;
			gap: 0.5rem;
		}

		.search-date-head {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 0.6rem;
			flex-wrap: wrap;
		}

		.search-date-head-label {
			font-size: 0.82rem;
			color: var(--color-text-muted);
		}

		.search-date-hint {
			font-size: 0.78rem;
			color: var(--color-text-muted);
		}

		.search-date-panel {
			border: 1px solid rgba(255, 255, 255, 0.14);
			border-radius: 0.9rem;
			background: rgba(255, 255, 255, 0.04);
			overflow: hidden;
		}

		.search-date-panel summary {
			list-style: none;
			cursor: pointer;
			padding: 0.66rem 0.82rem;
			font-size: 0.83rem;
			color: var(--color-text-secondary);
			display: flex;
			align-items: center;
			justify-content: space-between;
			user-select: none;
		}

		.search-date-panel summary::-webkit-details-marker {
			display: none;
		}

		.search-date-panel summary::after {
			content: "▾";
			font-size: 0.75rem;
			opacity: 0.85;
			transition: transform var(--transition);
		}

		.search-date-panel[open] summary::after {
			transform: rotate(180deg);
		}

		.search-date-panel[open] summary {
			border-bottom: 1px solid rgba(255, 255, 255, 0.12);
		}

		.search-date-body {
			display: grid;
			gap: 0.55rem;
			padding: 0.68rem 0.82rem 0.82rem;
		}

		.search-date-tip {
			margin: 0;
			font-size: 0.78rem;
			color: var(--color-text-muted);
		}

		.search-date-row {
			display: flex;
			gap: 0.72rem;
			flex-wrap: wrap;
		}

		.search-date-field {
			display: grid;
			gap: 0.36rem;
			flex: 1;
			min-width: min(100%, 11rem);
			font-size: 0.8rem;
			color: var(--color-text-muted);
		}

		.search-tags-panel {
			border: 1px solid rgba(255, 255, 255, 0.14);
			border-radius: 0.9rem;
			background: rgba(255, 255, 255, 0.04);
			overflow: hidden;
		}

		.search-tags-panel summary {
			list-style: none;
			cursor: pointer;
			padding: 0.66rem 0.82rem;
			font-size: 0.83rem;
			color: var(--color-text-secondary);
			display: flex;
			align-items: center;
			justify-content: space-between;
			user-select: none;
		}

		.search-tags-panel summary::-webkit-details-marker {
			display: none;
		}

		.search-tags-panel summary::after {
			content: "▾";
			font-size: 0.75rem;
			opacity: 0.85;
			transition: transform var(--transition);
		}

		.search-tags-panel[open] summary::after {
			transform: rotate(180deg);
		}

		.search-tags-panel[open] summary {
			border-bottom: 1px solid rgba(255, 255, 255, 0.12);
		}

		.search-tags {
			width: 100%;
			border: none;
			padding: 0.68rem 0.82rem 0.82rem;
			margin: 0;
			display: grid;
			gap: 0.55rem;
	}

	.search-tags legend {
		font-size: 0.82rem;
		color: var(--color-text-muted);
	}

	.search-tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.search-tag-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.4rem 0.62rem;
		border-radius: var(--radius-pill);
		border: 1px solid rgba(255, 255, 255, 0.2);
		background: rgba(255, 255, 255, 0.06);
		font-size: 0.8rem;
		color: var(--color-text);
		cursor: pointer;
	}

		.search-tag-chip input {
			margin: 0;
		}

		.sr-only {
			position: absolute;
			width: 1px;
			height: 1px;
			padding: 0;
			margin: -1px;
			overflow: hidden;
			clip: rect(0, 0, 0, 0);
			white-space: nowrap;
			border: 0;
		}

	.search-results {
		margin-top: var(--space-md);
	}

	@media (max-width: 640px) {
		.search-form {
			flex-direction: column;
		}

		.search-button {
			width: 100%;
		}
	}
</style>
