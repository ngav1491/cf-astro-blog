---
import Base from "@/layouts/Base.astro";

Astro.response.status = 404;
const missingPath = Astro.url.pathname || "/";
---

<Base title="404 - Trang không tồn tại" description="Trang không tồn tại, tuy nhiên bạn có thể thử terminal easter egg này.">
	<section
		class="not-found-terminal glass-panel"
		data-not-found-terminal="true"
		data-ai-endpoint="/api/ai/terminal-404"
		data-missing-path={missingPath}
	>
		<header class="terminal-header">
			<span class="terminal-dot terminal-dot-danger"></span>
			<span class="terminal-dot terminal-dot-warn"></span>
			<span class="terminal-dot terminal-dot-ok"></span>
			<strong class="terminal-title">404-terminal://not-found</strong>
		</header>

		<div class="terminal-log" data-terminal-log="true" role="log" aria-live="polite">
			<p class="terminal-line terminal-line-system">[404] Không tìm thấy đường dẫn: {missingPath}</p>
			<p class="terminal-line terminal-line-system">Chào mừng đến với terminal easter egg, nhập lệnh để AI bên ngoài trả về kết quả theo phong cách terminal.</p>
			<p class="terminal-line terminal-line-system">Có thể thử: help, whoami, ls, pwd, about</p>
		</div>

		<form class="terminal-form" data-terminal-form="true">
			<label class="terminal-input-wrap" for="terminalCommandInput">
				<span class="terminal-prompt">guest@404:~$</span>
				<input
			<input
				id="terminalCommandInput"
				class="terminal-input"
				name="command"
				type="text"
				placeholder="Nhập lệnh và nhấn Enter"
				autocomplete="off"
				spellcheck="false"
				data-terminal-input="true"
				maxlength="200"
				required
			/>
			<button type="submit" class="terminal-submit">Thực thi</button>
		</form>
	</section>
	<script is:inline src="/not-found-terminal.js"></script>
</Base>

<style>
	.not-found-terminal {
		display: grid;
		gap: 0.9rem;
		padding: clamp(1rem, 0.8rem + 1vw, 1.6rem);
		margin-bottom: 1.25rem;
		border: 1px solid rgba(96, 165, 250, 0.25);
		/* 透明度/模糊跟随后台「卡片」控制，与 friends / search 页面 glass-panel 保持一致 */
		--glass-panel-opacity: calc(var(--hero-card-opacity, 14) / 100);
		--glass-panel-blur: var(--hero-card-blur, 18px);
		/* 终端语义色（深色模式默认值） */
		--terminal-cmd-color: #a7f3d0;
		--terminal-error-color: #fca5a5;
		--terminal-prompt-color: #86efac;
	}

	/* 浅色主题：终端语义色切换为深色可读版本 */
	:root[data-theme="light"] .not-found-terminal {
		--terminal-cmd-color: #047857;
		--terminal-error-color: #dc2626;
		--terminal-prompt-color: #16a34a;
	}

	@media (prefers-color-scheme: light) {
		:root:not([data-theme="dark"]) .not-found-terminal {
			--terminal-cmd-color: #047857;
			--terminal-error-color: #dc2626;
			--terminal-prompt-color: #16a34a;
		}
	}

	.terminal-header {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		padding-bottom: 0.55rem;
		border-bottom: 1px solid var(--color-border);
	}

	.terminal-dot {
		width: 0.62rem;
		height: 0.62rem;
		border-radius: 999px;
	}

	.terminal-dot-danger {
		background: #ff5f56;
	}

	.terminal-dot-warn {
		background: #ffbd2e;
	}

	.terminal-dot-ok {
		background: #27c93f;
	}

	.terminal-title {
		margin-left: 0.35rem;
		font-size: 0.8rem;
		color: var(--color-text-secondary);
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Courier New", monospace;
	}

	.terminal-log {
		min-height: 300px;
		max-height: min(56vh, 520px);
		overflow: auto;
		padding: 0.2rem 0.1rem;
		display: grid;
		gap: 0.32rem;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Courier New", monospace;
		font-size: 0.88rem;
		line-height: 1.48;
	}

	.terminal-line {
		margin: 0;
		white-space: pre-wrap;
		word-break: break-word;
		color: var(--color-text);
	}

	.terminal-line-command {
		color: var(--terminal-cmd-color);
	}

	.terminal-line-system {
		color: var(--color-text-muted);
	}

	.terminal-line-error {
		color: var(--terminal-error-color);
	}

	.terminal-form {
		display: flex;
		gap: 0.62rem;
		align-items: center;
	}

	.terminal-input-wrap {
		flex: 1;
		min-width: 0;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.62rem 0.72rem;
		border: 1px solid var(--color-border);
		border-radius: 12px;
		background: var(--color-bg-tertiary);
	}

	.terminal-prompt {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Courier New", monospace;
		font-size: 0.84rem;
		color: var(--terminal-prompt-color);
		white-space: nowrap;
	}

	.terminal-input {
		flex: 1;
		min-width: 0;
		border: none;
		outline: none;
		color: var(--color-text);
		background: transparent;
		font: inherit;
	}

	.terminal-input::placeholder {
		color: var(--color-text-placeholder);
	}

	.terminal-submit {
		border: 1px solid rgba(96, 165, 250, 0.35);
		background: linear-gradient(120deg, rgba(30, 64, 175, 0.55), rgba(37, 99, 235, 0.36));
		color: rgba(239, 246, 255, 0.96);
		padding: 0.6rem 0.85rem;
		border-radius: 12px;
		font-size: 0.82rem;
		cursor: pointer;
	}

	.terminal-submit:hover {
		border-color: rgba(147, 197, 253, 0.58);
	}

	@media (max-width: 640px) {
		.terminal-form {
			flex-direction: column;
			align-items: stretch;
		}

		.terminal-submit {
			width: 100%;
		}
	}
</style>
