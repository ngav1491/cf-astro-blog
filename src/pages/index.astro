---
import { env } from "cloudflare:workers";
import { and, asc, desc, eq } from "drizzle-orm";
import PostCard from "@/components/PostCard.astro";
import { blogCategories, blogPosts } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";
import { formatDate } from "@/lib/format";
import { getPublicPostVisibilityCondition } from "@/lib/public-content";
import {
	buildHeroActionLinks,
	DEFAULT_SITE_APPEARANCE,
	getSiteAppearance,
	resolveSiteDescriptionFromAppearance,
} from "@/lib/site-appearance";
import { siteConfig } from "@/lib/types";

interface HomePostCardRow {
	title: string;
	slug: string;
	excerpt: string | null;
	publishedAt: string | null;
	authorName: string | null;
	categoryName: string | null;
	featuredImageKey: string | null;
	featuredImageAlt: string | null;
}

let pinnedPosts: HomePostCardRow[] = [];
let recentPosts: HomePostCardRow[] = [];
let homepageAppearance = DEFAULT_SITE_APPEARANCE;

try {
	const db = getDb(env.DB);
	homepageAppearance = await getSiteAppearance(db);

	pinnedPosts = await db
		.select({
			title: blogPosts.title,
			slug: blogPosts.slug,
			excerpt: blogPosts.excerpt,
			publishedAt: blogPosts.publishedAt,
			authorName: blogPosts.authorName,
			categoryName: blogCategories.name,
			featuredImageKey: blogPosts.featuredImageKey,
			featuredImageAlt: blogPosts.featuredImageAlt,
		})
		.from(blogPosts)
		.leftJoin(blogCategories, eq(blogPosts.categoryId, blogCategories.id))
		.where(
			and(getPublicPostVisibilityCondition(), eq(blogPosts.isPinned, true)),
		)
		.orderBy(
			asc(blogPosts.pinnedOrder),
			desc(blogPosts.publishedAt),
			desc(blogPosts.createdAt),
		)
		.limit(6);

	recentPosts = await db
		.select({
			title: blogPosts.title,
			slug: blogPosts.slug,
			excerpt: blogPosts.excerpt,
			publishedAt: blogPosts.publishedAt,
			authorName: blogPosts.authorName,
			categoryName: blogCategories.name,
			featuredImageKey: blogPosts.featuredImageKey,
			featuredImageAlt: blogPosts.featuredImageAlt,
		})
		.from(blogPosts)
		.leftJoin(blogCategories, eq(blogPosts.categoryId, blogCategories.id))
		.where(
			and(getPublicPostVisibilityCondition(), eq(blogPosts.isPinned, false)),
		)
		.orderBy(desc(blogPosts.publishedAt), desc(blogPosts.createdAt))
		.limit(3);
} catch {
	// Khi D1 không được bind, trang chủ sẽ hiển thị danh sách trống
}

const latestPost = [...pinnedPosts, ...recentPosts]
	.filter((post) => Boolean(post.publishedAt))
	.sort(
		(a, b) =>
			new Date(b.publishedAt ?? 0).getTime() -
			new Date(a.publishedAt ?? 0).getTime(),
	)[0];
const latestUpdateAt = latestPost?.publishedAt || null;
const latestUpdate = latestUpdateAt
	? formatDate(latestUpdateAt)
	: "Đang chờ bài viết chính thức đầu tiên được xuất bản";
const recentSectionSubheading =
	pinnedPosts.length > 0
		? ""
		: "Giữ lại những bài viết mới nhất, trang chủ chỉ làm cổng chọn lọc, nội dung đầy đủ xem ở trang lưu trữ.";
const heroActions = buildHeroActionLinks(homepageAppearance);
const homepageMetaDescription = resolveSiteDescriptionFromAppearance(
	homepageAppearance,
	siteConfig.description,
);

function isInternalHref(href: string) {
	return href.startsWith("/") && !href.startsWith("//");
}
---

<Base title={siteConfig.name} description={homepageMetaDescription}>
	<section class="home-hero glass-panel" data-hero-depth>
		<div class="hero-atmosphere" aria-hidden="true">
			<span class="hero-aura hero-aura-primary"></span>
			<span class="hero-aura hero-aura-secondary"></span>
			<span class="hero-grid"></span>
			<span class="hero-beam"></span>
		</div>
		<div class="home-hero-main">
			<div
				class:list={[
					"hero-main-media",
					{ "hero-main-media-has-image": Boolean(homepageAppearance.heroMainImagePath) },
				]}
				data-tilt-card
				data-tilt-scale="0.78"
				data-tilt-shift-scale="1.08"
				aria-hidden={homepageAppearance.heroMainImagePath ? undefined : "true"}
			>
				{
					homepageAppearance.heroMainImagePath ? (
						<img
							src={homepageAppearance.heroMainImagePath}
							alt=""
							loading="lazy"
							decoding="async"
						/>
					) : null
				}
			</div>
			<div class="home-hero-copy">
				<span class="section-kicker">{homepageAppearance.heroKicker}</span>
				<h1 class="page-title">{homepageAppearance.heroTitle}</h1>
				<p class="page-intro">{homepageAppearance.heroIntro}</p>
				<div class="hero-actions">
					{
						heroActions.map((action, index) => (
							index === 1 ? (
								<span class="hero-search-bridge" transition:name="search-entry">
									<a
										href={action.href}
										class:list={["button", { "button-secondary": index > 0 }]}
										target={isInternalHref(action.href) ? undefined : "_blank"}
										rel={isInternalHref(action.href) ? undefined : "noopener noreferrer"}
									>
										{action.label}
									</a>
								</span>
							) : (
								<a
									href={action.href}
									class:list={["button", { "button-secondary": index > 0 }]}
									target={isInternalHref(action.href) ? undefined : "_blank"}
									rel={isInternalHref(action.href) ? undefined : "noopener noreferrer"}
								>
									{action.label}
								</a>
							)
						))
					}
				</div>
			</div>
		</div>
			<div class="home-hero-side">
				<article
					class:list={[
						"hero-signal-card",
						{ "hero-signal-card-has-image": Boolean(homepageAppearance.heroSignalImagePath) },
					]}
					data-tilt-card
				>
					<div class="hero-signal-glow" aria-hidden="true"></div>
					{
						homepageAppearance.heroSignalImagePath ? (
							<div class="hero-signal-media" aria-hidden="true">
								<img
									src={homepageAppearance.heroSignalImagePath}
									alt=""
									loading="lazy"
									decoding="async"
								/>
							</div>
						) : null
					}
					<div class="hero-signal-content">
						<span class="hero-signal-label">{homepageAppearance.heroSignalLabel}</span>
						<strong class="hero-signal-heading">{homepageAppearance.heroSignalHeading}</strong>
						<p class="hero-signal-copy">{homepageAppearance.heroSignalCopy}</p>
						<div class="hero-signal-row">
							<span class="hero-signal-chip">{homepageAppearance.heroSignalChip1}</span>
							<span class="hero-signal-chip">{homepageAppearance.heroSignalChip2}</span>
							<span class="hero-signal-chip">{homepageAppearance.heroSignalChip3}</span>
						</div>
					</div>
				</article>
			<div class="hero-metric">
				<span>Cập nhật gần nhất</span>
				<strong>
					{
						latestUpdateAt ? (
							<time
								class="local-time-pending"
								datetime={latestUpdateAt}
								data-local-time="date"
							>
								{latestUpdate}
							</time>
						) : (
							latestUpdate
						)
					}
				</strong>
			</div>
		</div>
	</section>

	{
		pinnedPosts.length > 0 && (
			<>
				<section class="section-head">
	<section class="section-head">
		<div>
			<span class="section-kicker">Bài viết đã ghim</span>
			<h2 class="section-heading">Bài viết đã ghim</h2>
		</div>
	</section>
				<div class="home-grid home-grid-pinned">
					{pinnedPosts.map((post, index) => (
						<PostCard
							title={post.title}
							slug={post.slug}
							excerpt={post.excerpt}
							publishedAt={post.publishedAt}
							authorName={post.authorName}
							categoryName={post.categoryName}
							featuredImageKey={post.featuredImageKey}
							featuredImageAlt={post.featuredImageAlt}
							coverSide={index % 2 === 0 ? "left" : "right"}
						/>
					))}
				</div>
			</>
		)
	}

	<section class="section-head">
		<div>
			<span class="section-kicker">Cập nhật gần đây</span>
			<h2 class="section-heading">Cập nhật gần đây</h2>
		</div>
		<p class="section-subheading">
			{recentSectionSubheading}
		</p>
	</section>

	{recentPosts.length > 0 ? (
		<div class="home-grid">
			{recentPosts.map((post, index) => (
				<PostCard
					title={post.title}
					slug={post.slug}
					excerpt={post.excerpt}
					publishedAt={post.publishedAt}
					authorName={post.authorName}
					categoryName={post.categoryName}
					featuredImageKey={post.featuredImageKey}
					featuredImageAlt={post.featuredImageAlt}
					coverSide={index % 2 === 0 ? "left" : "right"}
				/>
			))}
		</div>
	) : (
		<div class="empty-state glass-panel">
			<p>Chưa có bài viết công khai, hãy đăng bài đầu tiên ở backend.</p>
		</div>
	)}
</Base>

<style>
	.home-hero {
		--hero-pointer-x: 0;
		--hero-pointer-y: 0;
		--hero-scroll-shift: 0px;
		--hero-opacity-scale: calc(var(--hero-card-opacity, 14) / 14);
		--glass-panel-blur: var(--hero-card-blur, 18px);
		--hero-blur-effective: min(calc(var(--hero-card-blur, 18px) * 1.6), 84px);
		--hero-surface-alpha: min(
			calc(var(--hero-card-opacity, 14) / 100),
			0.32
		);
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.9fr);
		gap: clamp(1.4rem, 2vw, 2.2rem);
		padding: clamp(1.5rem, 1rem + 3vw, 3rem);
		box-shadow:
			0 30px 90px -60px rgba(8, 18, 34, 0.34),
			0 12px 24px -18px rgba(8, 18, 34, 0.18);
	}

	.home-hero > :not(.hero-atmosphere) {
		position: relative;
		z-index: 3;
	}

	.home-hero::after {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: rgba(var(--card-surface-rgb), var(--hero-surface-alpha));
		backdrop-filter: blur(var(--hero-blur-effective)) saturate(152%);
		-webkit-backdrop-filter: blur(var(--hero-blur-effective)) saturate(152%);
		z-index: 2;
	}

	.hero-atmosphere {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		overflow: hidden;
	}

	.hero-atmosphere::before {
		content: "";
		position: absolute;
		inset: 0;
		background:
			linear-gradient(
				140deg,
				rgba(var(--card-sheen-rgb), calc(0.18 * var(--hero-opacity-scale))),
				rgba(var(--card-sheen-rgb), calc(0.08 * var(--hero-opacity-scale)))
			),
			radial-gradient(
				circle at 18% 20%,
				rgba(10, 132, 255, calc(0.14 * var(--hero-opacity-scale))),
				transparent 32%
			);
	}

	.hero-aura,
	.hero-grid,
	.hero-beam {
		position: absolute;
		transition:
			transform var(--nav-motion-surface),
			opacity var(--nav-motion-surface);
	}

	.hero-aura {
		border-radius: 50%;
		filter: blur(10px);
		opacity: 0.88;
	}

	.hero-aura-primary {
		top: -4rem;
		right: -2rem;
		width: 18rem;
		height: 18rem;
		background: radial-gradient(circle, rgba(10, 132, 255, 0.28), transparent 68%);
		transform: translate3d(
			calc(var(--hero-pointer-x) * -18px),
			calc(var(--hero-pointer-y) * -14px),
			0
		);
	}

	.hero-aura-secondary {
		left: 26%;
		bottom: -6rem;
		width: 16rem;
		height: 16rem;
		background: radial-gradient(circle, rgba(255, 255, 255, 0.22), transparent 70%);
		transform: translate3d(
			calc(var(--hero-pointer-x) * 14px),
			calc(var(--hero-pointer-y) * 10px),
			0
		);
	}

	.hero-grid {
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
		background-size: 3.25rem 3.25rem;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.7), transparent 88%);
		opacity: 0.5;
		transform: translate3d(
			calc(var(--hero-pointer-x) * -8px),
			calc(var(--hero-scroll-shift) * 0.08),
			0
		);
	}

	.hero-beam {
		right: 12%;
		top: -10%;
		width: 18rem;
		height: 130%;
		background: linear-gradient(
			180deg,
			rgba(255, 255, 255, 0),
			rgba(255, 255, 255, 0.18),
			rgba(255, 255, 255, 0)
		);
		opacity: 0.46;
		transform:
			rotate(24deg)
			translate3d(calc(var(--hero-pointer-x) * -10px), calc(var(--hero-pointer-y) * 12px), 0);
	}

		.home-hero-main,
		.home-hero-side {
			display: grid;
			gap: 1.1rem;
			transition: transform var(--nav-motion-surface);
		}

		.home-hero-side {
			height: 100%;
			grid-template-rows: minmax(0, 1fr) auto;
		}

	.home-hero-main {
		grid-template-rows: minmax(10rem, 1fr) auto;
		align-content: stretch;
		transform: translate3d(
			calc(var(--hero-pointer-x) * 12px),
			calc(var(--hero-pointer-y) * 10px + var(--hero-scroll-shift) * -0.05),
			0
		);
	}

	.home-hero-copy {
		display: grid;
		align-content: start;
		gap: 1.1rem;
	}

	.hero-main-media {
		position: relative;
		border-radius: calc(var(--radius-card) + 4px);
		border: 1px solid rgba(255, 255, 255, 0.14);
		background:
			linear-gradient(145deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0.08)),
			radial-gradient(circle at 16% 24%, rgba(10, 132, 255, 0.24), transparent 52%);
		overflow: hidden;
		min-height: clamp(8.8rem, 22vh, 14rem);
		box-shadow: 0 22px 44px -34px rgba(8, 18, 34, 0.34);
		transform:
			perspective(1200px)
			rotateX(var(--tilt-rotate-x, 0deg))
			rotateY(var(--tilt-rotate-y, 0deg))
			scale3d(1.008, 1.008, 1.008);
		transform-style: preserve-3d;
		transition:
			transform var(--nav-motion-surface),
			box-shadow var(--nav-motion-surface),
			border-color var(--nav-motion-surface);
		opacity: 0;
		animation: home-reveal-in 820ms cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 80ms;
	}

	.hero-main-media::before {
		content: "";
		position: absolute;
		inset: 0;
		background:
			linear-gradient(
				128deg,
				rgba(255, 255, 255, 0.18) 0%,
				rgba(255, 255, 255, 0.04) 42%,
				rgba(255, 255, 255, 0) 100%
			),
			repeating-linear-gradient(
				115deg,
				rgba(255, 255, 255, 0.1) 0 11px,
				rgba(255, 255, 255, 0.03) 11px 22px
			);
		transform: translate3d(
			calc(var(--tilt-shift-x, 0) * -5px),
			calc(var(--tilt-shift-y, 0) * -5px),
			24px
		);
		transition: transform var(--nav-motion-surface);
	}

	.hero-main-media-has-image::before {
		background: linear-gradient(
			180deg,
			rgba(15, 23, 42, 0.12),
			rgba(15, 23, 42, 0.24)
		);
	}

	.hero-main-media img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transform: translate3d(
			calc(var(--tilt-shift-x, 0) * 8px),
			calc(var(--tilt-shift-y, 0) * 8px),
			20px
		)
			scale(1.04);
		transition: transform var(--nav-motion-surface);
	}

	.hero-main-media:not(.hero-main-media-has-image)::after {
		content: "Vị trí dự phòng cho ảnh";
		position: absolute;
		right: 0.9rem;
		bottom: 0.75rem;
		padding: 0.36rem 0.62rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.18);
		background: rgba(15, 23, 42, 0.3);
		color: rgba(255, 255, 255, 0.78);
		font-size: 0.72rem;
		letter-spacing: 0.08em;
		transform: translate3d(
			calc(var(--tilt-shift-x, 0) * 3px),
			calc(var(--tilt-shift-y, 0) * 3px),
			28px
		);
		transition: transform var(--nav-motion-surface);
	}

	.home-hero-side {
		align-content: start;
		transform: translate3d(
			calc(var(--hero-pointer-x) * -10px),
			calc(var(--hero-pointer-y) * -8px + var(--hero-scroll-shift) * 0.04),
			0
		);
	}

	.home-hero-main .page-title {
		max-width: 12ch;
		font-size: clamp(2.8rem, 2.1rem + 2vw, 4.9rem);
		line-height: 0.98;
	}

	.home-hero-copy .page-intro {
		white-space: pre-line;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 0.4rem;
	}

	.hero-search-bridge {
		display: inline-flex;
	}

	.hero-actions .button-secondary {
		border: none;
		background: rgba(255, 255, 255, 0.13);
	}

	.hero-actions .button-secondary:hover {
		background: rgba(255, 255, 255, 0.19);
	}

	.hero-actions .button-secondary {
		border: none;
		background: rgba(255, 255, 255, 0.13);
	}

	.hero-actions .button-secondary:hover {
		background: rgba(255, 255, 255, 0.19);
	}

	.home-hero-side {
		padding: 0.35rem;
		border-radius: var(--radius-card);
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.08);
	}

	.home-hero-copy > * {
		animation: home-float-in 780ms cubic-bezier(0.22, 1, 0.36, 1) both;
	}

	.home-hero-copy > :nth-child(1) {
		animation-delay: 40ms;
	}

	.home-hero-copy > :nth-child(2) {
		animation-delay: 120ms;
	}

	.home-hero-copy > :nth-child(3) {
		animation-delay: 190ms;
	}

	.home-hero-copy > :nth-child(4) {
		animation-delay: 260ms;
	}

		.hero-signal-card {
			--hero-signal-pane-bg: rgba(255, 255, 255, 0.24);
			--hero-signal-pane-border: rgba(255, 255, 255, 0.36);
			--hero-signal-label-bg: rgba(255, 255, 255, 0.3);
			--hero-signal-label-border: rgba(255, 255, 255, 0.34);
			--hero-signal-chip-bg: rgba(255, 255, 255, 0.3);
			--hero-signal-chip-border: rgba(255, 255, 255, 0.3);
			position: relative;
			display: block;
			height: 100%;
			border-radius: calc(var(--radius-card) + 4px);
			background:
				linear-gradient(145deg, rgba(255, 255, 255, 0.26), rgba(255, 255, 255, 0.1)),
				radial-gradient(circle at 18% 18%, rgba(10, 132, 255, 0.18), transparent 42%);
			border: 1px solid rgba(255, 255, 255, 0.16);
			box-shadow: 0 24px 50px -34px rgba(8, 18, 34, 0.3);
			overflow: hidden;
			transform:
				perspective(1200px)
				rotateX(var(--tilt-rotate-x, 0deg))
			rotateY(var(--tilt-rotate-y, 0deg))
			scale3d(1.01, 1.01, 1.01);
		transform-style: preserve-3d;
		transition:
			transform var(--nav-motion-surface),
			box-shadow var(--nav-motion-surface),
			border-color var(--nav-motion-surface);
			opacity: 0;
			animation: home-reveal-in 820ms cubic-bezier(0.22, 1, 0.36, 1) both;
			animation-delay: 130ms;
		}

		:global([data-theme="dark"]) .hero-signal-card {
			--hero-signal-pane-bg: rgba(9, 18, 32, 0.3);
			--hero-signal-pane-border: rgba(255, 255, 255, 0.24);
			--hero-signal-label-bg: rgba(255, 255, 255, 0.14);
			--hero-signal-label-border: rgba(255, 255, 255, 0.14);
			--hero-signal-chip-bg: rgba(255, 255, 255, 0.16);
			--hero-signal-chip-border: rgba(255, 255, 255, 0.16);
		}

		@media (prefers-color-scheme: dark) {
			:global(:root:not([data-theme="light"])) .hero-signal-card {
				--hero-signal-pane-bg: rgba(9, 18, 32, 0.3);
				--hero-signal-pane-border: rgba(255, 255, 255, 0.24);
				--hero-signal-label-bg: rgba(255, 255, 255, 0.14);
				--hero-signal-label-border: rgba(255, 255, 255, 0.14);
				--hero-signal-chip-bg: rgba(255, 255, 255, 0.16);
				--hero-signal-chip-border: rgba(255, 255, 255, 0.16);
			}
		}

		.hero-signal-card-has-image {
			background: rgba(255, 255, 255, 0.1);
			display: flex;
			flex-direction: column;
			justify-content: flex-end;
		}

		.hero-signal-content {
			position: relative;
			z-index: 1;
			display: grid;
			gap: 0.85rem;
			padding: 1.25rem;
		}

		.hero-signal-card-has-image .hero-signal-content {
			margin-top: auto;
			border-top: 1px solid var(--hero-signal-pane-border);
			background: var(--hero-signal-pane-bg);
			backdrop-filter: blur(min(calc(var(--hero-card-blur, 18px) * 1.5), 56px))
